# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL where /book/[slug] is publicly accessible
NEXT_PUBLIC_BOOKING_BASE_URL=

# Secret salt mixed into QR token generation. Generate with: openssl rand -hex 32
QR_TOKEN_SECRET=

# Razorpay — get these from razorpay.com/dashboard > Settings > API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=   # same value as RAZORPAY_KEY_ID (safe to expose)

# Razorpay plan IDs — create plans in razorpay.com/dashboard > Subscriptions > Plans
RAZORPAY_PLAN_ID_BASIC=        # plan_XXXXXXXXXXXXXX for ₹399/month
RAZORPAY_PLAN_ID_PRO=          # plan_XXXXXXXXXXXXXX for ₹799/month

# Razorpay webhook secret — set in razorpay.com/dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=
