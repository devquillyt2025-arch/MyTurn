# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL where /book/[slug] is publicly accessible
NEXT_PUBLIC_BOOKING_BASE_URL=

# Razorpay — get these from razorpay.com/dashboard > Settings > API Keys
RAZORPAY_KEY_ID=REDACTED
RAZORPAY_KEY_SECRET=REDACTED
NEXT_PUBLIC_RAZORPAY_KEY_ID=REDACTED   # same value as RAZORPAY_KEY_ID (safe to expose)

# Razorpay plan IDs — create plans in razorpay.com/dashboard > Subscriptions > Plans
RAZORPAY_PLAN_ID_BASIC=plan_T1VhaLWVJMZri1       # plan_XXXXXXXXXXXXXX for ₹999/month
RAZORPAY_PLAN_ID_PRO=plan_T1Vgx03OVClyjG       # plan_XXXXXXXXXXXXXX for ₹1999/month

# Razorpay webhook secret — set in razorpay.com/dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=REDACTED
